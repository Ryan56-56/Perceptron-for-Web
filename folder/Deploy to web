<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Perceptron L vs T Classifier</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <main>
    <h1>Perceptron L vs T Classifier</h1>
    <p>Train a perceptron on 4×4 binary letter patterns and classify handwritten L / T shapes.</p>

    <section class="panel">
      <div id="grid" class="grid"></div>
      <div class="actions">
        <button id="btn-random">Load random sample</button>
        <button id="btn-predict">Predict current grid</button>
        <button id="btn-clear">Clear grid</button>
      </div>
    </section>

    <section class="info">
      <p id="metrics"></p>
      <p id="result"></p>
      <p id="sample-label"></p>
      <p id="note"></p>
    </section>

    <section class="details">
      <h2>Training data</h2>
      <p>120 labeled patterns generated from annotated L and T prototypes.</p>
      <p>Each sample is a 4×4 binary image encoded as 16 pixel values.</p>
    </section>
  </main>
  <script src="script.js"></script>
</body>
</html>
